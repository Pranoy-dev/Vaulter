# Copy to `.env.local` and fill in your keys.
# Next.js does not read this file — only `.env.local` / `.env` are loaded.

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Clerk Auth (https://dashboard.clerk.com → your app → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect paths (optional — these are the defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
